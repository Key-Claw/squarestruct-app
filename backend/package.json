{
    "name": "squarestruct-backend",
    "version": "1.0.0",
    "description": "Backend de SquareStruct",
    "main": "server.js",
    "type": "module",
    "scripts": {
      "dev": "nodemon server.js",
      "start": "node server.js",
      "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
      "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit --runInBand",
      "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration --runInBand"
    },
    "dependencies": {
      "bcrypt": "^5.1.1",
      "cors": "^2.8.5",
      "dotenv": "^16.4.5",
      "express": "^5.1.0",
      "jsonwebtoken": "^9.0.2",
      "mysql2": "^3.11.3"
    },
    "devDependencies": {
      "jest": "^29.7.0",
      "nodemon": "^3.1.4",
      "supertest": "^7.0.0"
    }
  }